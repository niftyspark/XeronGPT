rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: conversations
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - The UID of the user who owns this conversation.
    //   - title: string (required, max 200 chars) - A short title for the conversation.
    //   - createdAt: timestamp (required) - When the conversation was created.
    //   - updatedAt: timestamp (required) - When the conversation was last updated.
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - conversationId: string (required) - The ID of the conversation this message belongs to.
    //   - role: string (required, enum: user, assistant, system) - The role of the message sender.
    //   - content: string (required, max 100000 chars) - The text content of the message.
    //   - createdAt: timestamp (required) - When the message was created.
    //   - userId: string (required) - The UID of the user who owns this message.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidConversation() {
      return hasOnlyAllowedFields(['userId', 'title', 'createdAt', 'updatedAt']) &&
             hasRequiredFields(['userId', 'title', 'createdAt', 'updatedAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('title', 1, 200) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidMessage() {
      return hasOnlyAllowedFields(['conversationId', 'role', 'content', 'createdAt', 'userId']) &&
             hasRequiredFields(['conversationId', 'role', 'content', 'createdAt', 'userId']) &&
             validStringLength('conversationId', 1, 128) &&
             request.resource.data.role in ['user', 'assistant', 'system'] &&
             validStringLength('content', 0, 100000) &&
             request.resource.data.createdAt is timestamp &&
             validStringLength('userId', 1, 128);
    }

    function isValidMemory() {
      return hasOnlyAllowedFields(['userId', 'content', 'updatedAt']) &&
             hasRequiredFields(['userId', 'content', 'updatedAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('content', 0, 10000) &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidCanvasState() {
      return hasOnlyAllowedFields(['userId', 'messages', 'code', 'updatedAt']) &&
             hasRequiredFields(['userId', 'messages', 'code', 'updatedAt']) &&
             validStringLength('userId', 1, 128) &&
             request.resource.data.messages is list &&
             validStringLength('code', 0, 1000000) &&
             request.resource.data.updatedAt is timestamp;
    }

    function isValidTask() {
      return hasOnlyAllowedFields(['userId', 'title', 'date', 'time', 'description', 'status', 'createdAt']) &&
             hasRequiredFields(['userId', 'title', 'date', 'time', 'description', 'status', 'createdAt']) &&
             validStringLength('userId', 1, 128) &&
             validStringLength('title', 1, 200) &&
             validStringLength('date', 1, 20) &&
             validStringLength('time', 1, 20) &&
             validStringLength('description', 0, 10000) &&
             request.resource.data.status in ['pending', 'completed'] &&
             request.resource.data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /conversations/{conversationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                       isValidConversation() && 
                       uidUnchanged();
      allow update: if isDocOwner() && 
                       isValidConversation() && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                       isValidMessage() && 
                       uidUnchanged();
      allow update: if isDocOwner() && 
                       isValidMessage() && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt &&
                       request.resource.data.conversationId == resource.data.conversationId &&
                       request.resource.data.role == resource.data.role;
      allow delete: if isDocOwner();
    }

    match /memories/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMemory();
      allow update: if isOwner(userId) && isValidMemory();
      allow delete: if isOwner(userId);
    }

    match /canvas_states/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCanvasState();
      allow update: if isOwner(userId) && isValidCanvasState();
      allow delete: if isOwner(userId);
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                       isValidTask() && 
                       uidUnchanged();
      allow update: if isDocOwner() && 
                       isValidTask() && 
                       uidNotModified() &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isDocOwner();
    }
  }
}
